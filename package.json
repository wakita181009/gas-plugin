{
  "name": "gas-plugin-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @gas-plugin/unplugin build && vitest run --config e2e/vitest.config.ts",
    "check": "biome check .",
    "check:fix": "biome check . --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.14.0"
}
