{
  "name": "@gas-plugin/cli",
  "version": "0.1.0",
  "description": "Extensible CLI tool for scaffolding Google Apps Script projects",
  "type": "module",
  "bin": {
    "gas-plugin": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./create": {
      "types": "./dist/commands/create.d.ts",
      "import": "./dist/commands/create.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && node scripts/postbuild.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "vite build && node scripts/postbuild.js"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "cli",
    "scaffold",
    "create",
    "unplugin"
  ],
  "author": "wakita181009",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
