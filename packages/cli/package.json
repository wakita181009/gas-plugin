{
  "name": "@gas-plugin/cli",
  "version": "0.1.3",
  "description": "Extensible CLI tool for scaffolding Google Apps Script projects",
  "type": "module",
  "bin": {
    "gas-plugin": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./create": {
      "types": "./dist/commands/create.d.ts",
      "import": "./dist/commands/create.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "vite build"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "cli",
    "scaffold",
    "create",
    "unplugin"
  ],
  "author": "wakita181009",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@gas-plugin/unplugin": "workspace:*",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/google-apps-script": "^2.0.11",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "rollup": "^4.62.2",
    "ts-loader": "^9.6.2",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  }
}
