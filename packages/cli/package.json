{
  "name": "@gas-plugin/cli",
  "version": "0.2.1",
  "description": "Extensible CLI tool for scaffolding Google Apps Script projects",
  "type": "module",
  "bin": {
    "gas-plugin": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./create": {
      "types": "./dist/commands/create.d.ts",
      "import": "./dist/commands/create.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "vite build"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "cli",
    "scaffold",
    "create",
    "unplugin"
  ],
  "author": "wakita181009",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@gas-plugin/unplugin": "workspace:*",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/google-apps-script": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "rollup": "catalog:",
    "ts-loader": "^9.6.2",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "yaml": "^2.9.0"
  }
}
